---

<div id="splash-screen" class="fixed inset-0 z-100 bg-[#FAFAFA] flex flex-col items-center justify-center transition-opacity duration-500">
  <img 
    src="https://sabiduriadealma.com/wp-content/uploads/2021/04/favicon-Arbol-de-la-Kabala.png" 
    alt="Arbol de la Kabala" 
    class="w-24 h-24 mb-8 object-contain"
  />
  
  <div class="inline-block h-8 w-8 animate-spin rounded-full border-4 border-solid border-brand-secondary border-r-transparent align-[-0.125em]" role="status">
    <span class="absolute! -m-px! h-px! w-px! overflow-hidden! whitespace-nowrap! border-0! p-0! [clip:rect(0,0,0,0)]!">Cargando...</span>
  </div>
</div>

<script is:inline>
  // Se ejecuta inmediatamente para evitar parpadeos
  const splash = document.getElementById('splash-screen');
  
  if (sessionStorage.getItem('splashShown') === 'true') {
    if (splash) splash.style.display = 'none';
  } else {
    // Cuando la pagina este completamente cargada, iniciar el contador
    window.addEventListener('load', () => {
      setTimeout(() => {
        if (splash) {
          splash.classList.add('opacity-0');
          setTimeout(() => {
            splash.style.display = 'none';
            sessionStorage.setItem('splashShown', 'true');
          }, 500); // Este tiempo debe coincidir con duration-500 de Tailwind
        }
      }, 1500); // Mostrar por 1.5 segundos
    });
  }
</script>
