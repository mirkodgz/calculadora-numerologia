---
import Layout from '../layouts/Layout.astro';
---

<Layout title="¡Correo Confirmado! | Sabiduría de Alma">
  <main class="min-h-screen flex items-center justify-center relative bg-[var(--color-brand-bg)] overflow-hidden">
    
    <!-- Background Elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-gradient-to-br from-[#e6b866]/10 to-transparent rounded-full blur-[100px]"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] bg-gradient-to-tl from-[#B11252]/5 to-transparent rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-xl mx-auto px-4 z-10 w-full">
      <div class="bg-white/80 backdrop-blur-2xl rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white/60 overflow-hidden p-8 sm:p-14 text-center">
        
        <!-- Icon -->
        <div class="mx-auto w-24 h-24 bg-green-50 rounded-full flex items-center justify-center mb-8 shadow-inner border border-green-100/50">
          <svg class="w-12 h-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>

        <h1 class="text-3xl sm:text-4xl font-serif text-slate-800 font-bold mb-4 tracking-tight">
          ¡Correo Confirmado!
        </h1>
        
        <p class="text-slate-600 font-sans text-lg sm:text-xl font-medium leading-relaxed mb-10">
          Tu identidad ha sido verificada con éxito. En estos mismos instantes, el cosmos está encriptando tu información.
        </p>

        <div class="bg-blue-50/50 border border-blue-100 rounded-xl p-6 text-left shadow-sm">
          <h3 class="font-bold text-slate-700 uppercase tracking-widest text-[11px] mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Siguiente Paso
          </h3>
          <p class="text-slate-600 text-sm font-medium leading-relaxed">
            Vuelve a tu bandeja de entrada. Vas a recibir un correo definitivo con el <strong class="text-[#B11252]">Enlace Mágico</strong> único para revelar tu <em>Mapa Numerológico Cabalístico</em> completo.
          </p>
        </div>

        <div class="mt-8">
          <a href="/" class="text-[#e6b866] hover:text-[#B11252] font-semibold text-sm transition-colors uppercase tracking-widest">
            ← Volver a la página principal
          </a>
        </div>

      </div>
    </div>
  </main>
</Layout>
