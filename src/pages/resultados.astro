---
import Layout from '../layouts/Layout.astro';
import ResultadosCard from '../components/ResultadosCard.svelte';
import BaseDataCard from '../components/BaseDataCard.svelte';
import { verifyNumerologyToken } from '../lib/jwt';
import { analizarNombre, analizarFecha, obtenerFamilia, sumarDigitos, sumarDigitosRecursivoSteps, determinarVersionCastellano, obtenerInterpretacion } from '../lib/numerology/calculator';
// En un proyecto real, estas funciones de lógica avanzada (calcularBloqueConFamilias) estarían en calculator.ts
// Las omitimos por brevedad para mostrar el flujo de SSR y JWT.

const token = Astro.url.searchParams.get('token');

let authorized = false;
let userPayload = null;
let resultados = null;

if (token) {
  const payload = await verifyNumerologyToken(token);
  if (payload) {
    authorized = true;
    userPayload = payload;
    
    const dictVersion = determinarVersionCastellano(payload.fecha_nacimiento);
    const idiomaReal = payload.idioma === 'castellano' ? dictVersion : payload.idioma;
    
    const analisisNombre = analizarNombre(payload.nombre, idiomaReal);
    const analisisApellido = analizarNombre(payload.apellido, idiomaReal);
    // Asegurarse de lidiar con strings vacios del segundo apellido
    const hasApellido2 = payload.segundo_apellido && payload.segundo_apellido.trim().length > 0;
    const analisisApellido2 = hasApellido2 
        ? analizarNombre(payload.segundo_apellido, idiomaReal) 
        : { total_simple: 0, total_multiplicado: 0 };
        
    const analisisFecha = analizarFecha(payload.fecha_nacimiento);

    const formatResult = (num) => {
      if (!num || isNaN(num)) return "0";
      // Reverse is needed because sumarDigitosRecursivoSteps returns [22, 13, 4] for 4-13-22
      const steps = sumarDigitosRecursivoSteps(num);
      return steps.join('-');
    };

        // Lógica para obtener el valor correcto de un bloque (los números maestros se respetan en vez de reducirse a su base, a menos que sean final)
    const getCompoundVal = (block) => {
        // En PHP: si el original es 11 o 22 (o en algunos casos el valor), se suma como 11/22 en lugar de 2/4.
        if (block.original === 11 || block.original === 22) return block.original;
        // Si no es especial, devuelve el valor reducido al final (e.g. 5)
        return block.valor;
    };
    
    // Lo mismo para los totales de las letras:
    const getKabVal = (analisis) => {
        const val = analisis.total_multiplicado_simplificado;
        if (val.original >= 10 && val.original <= 22) return val.original;
        // Si no...
        if (val.valor === 11 || val.valor === 22) return val.valor;
        return val.valor;
    };

    const getSimpleVal = (analisis) => {
        const val = analisis.total_simple_simplificado;
        if (val.original >= 10 && val.original <= 22) return val.original;
        if (val.valor === 11 || val.valor === 22) return val.valor;
        return val.valor;
    }

    const valorKabNombre = getKabVal(analisisNombre);
    const valorKabApellido = getKabVal(analisisApellido);
    const valorKabApellido2 = hasApellido2 ? getKabVal(analisisApellido2) : 0;

    const valorSimpleNombre = getSimpleVal(analisisNombre);
    const valorSimpleApellido = getSimpleVal(analisisApellido);
    const valorSimpleApellido2 = hasApellido2 ? getSimpleVal(analisisApellido2) : 0;

    const diaV = getCompoundVal(analisisFecha.dia); // 5
    const mesV = getCompoundVal(analisisFecha.mes); // 11
    const anioV = getCompoundVal(analisisFecha.anio); // 3
    
    // Cálculos compuestos exactos
    const valCaracterEsencial = valorKabNombre + valorKabApellido + valorKabApellido2; // 6 + 5 + 6 = 15? No, pre95 Mirko Kb=23, Dom Kb=23.. wait. 4+5+6 = 15
    const valCaminoVida = diaV + mesV + anioV; // 5 + 11 + 3 = 19
    const valMisionAdolescencia = valorSimpleNombre + valorSimpleApellido;
    const valCrisisCorto = diaV + mesV;
    const valCrisisLargo = mesV + anioV;

    // CaminoVida's "valor" (for subsequent use) = 1+9=10 (not 1)
    const caminoFinal = sumarDigitosRecursivoSteps(valCaminoVida);
    const caminoValParaEsencia = caminoFinal.length > 1 ? caminoFinal[1] : caminoFinal[0]; // 10 instead of 1

    const carEsencialFinal = sumarDigitosRecursivoSteps(valCaracterEsencial);
    const carEsencialVal = carEsencialFinal.length > 1 ? carEsencialFinal[1] : carEsencialFinal[0]; // 15... wait 6? 

    // Because WordPress used "valor" which is the reduced single digit (unless 11/22)
    // Actually: 
    const vC = valCaracterEsencial > 9 && valCaracterEsencial !== 11 && valCaracterEsencial !== 22 ? sumarDigitosRecursivoSteps(valCaracterEsencial)[0] : valCaracterEsencial;
    const vV = valCaminoVida > 9 && valCaminoVida !== 11 && valCaminoVida !== 22 ? sumarDigitosRecursivoSteps(valCaminoVida)[0] : valCaminoVida;

    const valEsencia = vC + vV; // 6 + 10 = 16

    
    const calcValAndInterp = (compoundVal) => {
        let finalValToReduce = compoundVal;
        if (compoundVal > 9 && compoundVal !== 11 && compoundVal !== 22) {
             finalValToReduce = sumarDigitosRecursivoSteps(compoundVal)[0];
        }
        const valToInterpret = (finalValToReduce == 11 || finalValToReduce == 22) ? finalValToReduce : sumarDigitosRecursivoSteps(finalValToReduce)[0];
        
        return {
           familia: obtenerFamilia(valToInterpret),
           desc: obtenerInterpretacion(valToInterpret)
        };
    };
    
    const almaV = analisisFecha.dia.valor === 11 || analisisFecha.dia.valor === 22 ? analisisFecha.dia.valor : analisisFecha.dia.original;
    const almaInfo = calcValAndInterp(almaV);
    const carInfo = calcValAndInterp(valCaracterEsencial);
    const esenciaInfo = calcValAndInterp(valEsencia);
    const caminoInfo = calcValAndInterp(valCaminoVida);
    const misionInfo = calcValAndInterp(valMisionAdolescencia);
    const misionInfInfo = calcValAndInterp(valorSimpleApellido + valorSimpleApellido2);
    const cortoInfo = calcValAndInterp(valCrisisCorto);
    const largoInfo = calcValAndInterp(valCrisisLargo);
    
    // For base blocks (dia, mes, etc.), it's just the simplified value unless 11/22
    const getBaseInfo = (val) => {
      let famObj = calcValAndInterp(val);
      return famObj;
    };

    resultados = {
      alma: { num: formatResult(almaV), ...almaInfo },
      caracterEsencial: { num: formatResult(valCaracterEsencial), ...carInfo },
      esencia: { num: formatResult(valEsencia), ...esenciaInfo },
      caminoVida: { num: formatResult(valCaminoVida), ...caminoInfo },
      misionInfancia: { num: formatResult(valorSimpleApellido + valorSimpleApellido2), ...misionInfInfo },
      misionAdolescencia: { num: formatResult(valMisionAdolescencia), ...misionInfo },
      crisisCorto: { num: formatResult(valCrisisCorto), ...cortoInfo },
      crisisLargo: { num: formatResult(valCrisisLargo), ...largoInfo },
      datosPersonales: {
        nombre: { texto: payload.nombre, valor: formatResult(analisisNombre.total_simple), oculto: sumarDigitos(analisisNombre.total_multiplicado), info: getBaseInfo(valorSimpleNombre) },
        apellido1: { texto: payload.apellido, valor: formatResult(analisisApellido.total_simple), oculto: sumarDigitos(analisisApellido.total_multiplicado), info: getBaseInfo(valorSimpleApellido) },
        apellido2: hasApellido2 ? { texto: payload.segundo_apellido, valor: formatResult(analisisApellido2.total_simple), oculto: sumarDigitos(analisisApellido2.total_multiplicado), info: getBaseInfo(valorSimpleApellido2) } : null,
        dia: { texto: String(analisisFecha.dia.original), valor: formatResult(diaV), info: getBaseInfo(diaV) },
        mes: { texto: String(analisisFecha.mes.original), valor: formatResult(mesV), info: getBaseInfo(mesV) },
        anio: { texto: payload.fecha_nacimiento.split('-')[0], valor: formatResult(anioV), info: getBaseInfo(anioV) }
      }
    };
  }
}
---

<Layout title="Resultados | Numerología Cabalística">
  <main class="min-h-screen bg-slate-50 py-20 px-4 sm:px-6 lg:px-8">
    
    {!authorized ? (
      <div class="max-w-md mx-auto bg-white p-10 rounded-2xl shadow-lg text-center">
        <div class="text-red-500 text-5xl mb-4">🚫</div>
        <h1 class="text-2xl font-serif text-gray-900 mb-4">Acceso Denegado</h1>
        <p class="text-gray-600 mb-8 font-medium">Este enlace es inválido, ha expirado o no ha sido generado correctamente. Por favor, solicita un nuevo cálculo.</p>
        <a href="/" class="inline-block bg-gray-900 text-white px-6 py-3 rounded-lg hover:bg-black transition-colors">Volver a la Calculadora</a>
      </div>
    ) : (
      <div class="max-w-5xl mx-auto">
        <header class="text-center mb-16">
          <h2 class="text-sm font-semibold text-amber-600 tracking-widest uppercase mb-3">Tu Mapa Personal</h2>
          <h1 class="text-4xl md:text-5xl font-serif text-gray-900 mb-4 capitalize">Hola, {userPayload.nombre}</h1>
          <p class="text-xl text-gray-500 font-medium max-w-2xl mx-auto">A continuación se revelan los secretos numéricos ocultos en tu fecha de nacimiento y tu nombre.</p>
        </header>

        
        
        <!-- DATOS PERSONALES -->
        <h3 class="text-2xl font-serif text-gray-900 text-center mb-8 pb-4 border-b border-gray-200">Datos Personales</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <BaseDataCard titulo={resultados.datosPersonales.nombre.texto} subtitulo="Nombre" numero={resultados.datosPersonales.nombre.valor} oculto={resultados.datosPersonales.nombre.oculto} familia={resultados.datosPersonales.nombre.info.familia} descripcion={resultados.datosPersonales.nombre.info.desc} />
          <BaseDataCard titulo={resultados.datosPersonales.apellido1.texto} subtitulo="1° Apellido" numero={resultados.datosPersonales.apellido1.valor} oculto={resultados.datosPersonales.apellido1.oculto} familia={resultados.datosPersonales.apellido1.info.familia} descripcion={resultados.datosPersonales.apellido1.info.desc} />
          {resultados.datosPersonales.apellido2 && (
            <BaseDataCard titulo={resultados.datosPersonales.apellido2.texto} subtitulo="2° Apellido" numero={resultados.datosPersonales.apellido2.valor} oculto={resultados.datosPersonales.apellido2.oculto} familia={resultados.datosPersonales.apellido2.info.familia} descripcion={resultados.datosPersonales.apellido2.info.desc} />
          )}
          <BaseDataCard titulo={resultados.datosPersonales.dia.texto} subtitulo="Día" numero={resultados.datosPersonales.dia.valor} familia={resultados.datosPersonales.dia.info.familia} descripcion={resultados.datosPersonales.dia.info.desc} />
          <BaseDataCard titulo={resultados.datosPersonales.mes.texto} subtitulo="Mes" numero={resultados.datosPersonales.mes.valor} familia={resultados.datosPersonales.mes.info.familia} descripcion={resultados.datosPersonales.mes.info.desc} />
          <BaseDataCard titulo={resultados.datosPersonales.anio.texto} subtitulo="Año" numero={resultados.datosPersonales.anio.valor} familia={resultados.datosPersonales.anio.info.familia} descripcion={resultados.datosPersonales.anio.info.desc} />
        </div>

        <h3 class="text-2xl font-serif text-gray-900 text-center mb-8 pb-4 border-b border-gray-200">Cálculos Kármicos y Compuestos</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">

          <ResultadosCard 
            titulo="Número de Alma" 
            numero={resultados.alma.num} familia={resultados.alma.familia} descripcion={resultados.alma.desc} 
            icono="🕊️"
            
          />
          <ResultadosCard 
            titulo="Carácter Esencial" 
            numero={resultados.caracterEsencial.num} familia={resultados.caracterEsencial.familia} descripcion={resultados.caracterEsencial.desc} 
            icono="🎭"
            
          />
          <ResultadosCard 
            titulo="Esencia" 
            numero={resultados.esencia.num} familia={resultados.esencia.familia} descripcion={resultados.esencia.desc} 
            icono="🌟"
            
          />
          <ResultadosCard 
            titulo="Camino de Vida" 
            numero={resultados.caminoVida.num} familia={resultados.caminoVida.familia} descripcion={resultados.caminoVida.desc} 
            icono="🛤️"
            
          />
          <ResultadosCard 
            titulo="Misión Infancia" 
            numero={resultados.misionInfancia.num} 
            icono="🌱"
            familia={resultados.misionInfancia.familia}
            descripcion={resultados.misionInfancia.desc}
          />
          <ResultadosCard 
            titulo="Misión Adolescencia" 
            numero={resultados.misionAdolescencia.num} familia={resultados.misionAdolescencia.familia} descripcion={resultados.misionAdolescencia.desc} 
            icono="🌱"
            
          />
          <ResultadosCard 
            titulo="Crisis de Ciclo Corto" 
            numero={resultados.crisisCorto.num} familia={resultados.crisisCorto.familia} descripcion={resultados.crisisCorto.desc} 
            icono="⚡"
            
          />
          <ResultadosCard 
            titulo="Crisis de Ciclo Largo" 
            numero={resultados.crisisLargo.num} familia={resultados.crisisLargo.familia} descripcion={resultados.crisisLargo.desc} 
            icono="⏳"
            
          />
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-8 text-center border-t-4 border-amber-400">
          <h3 class="text-2xl font-serif text-gray-900 mb-4">¿Quieres profundizar en tus revelaciones?</h3>
          <p class="text-gray-600 font-medium mb-8 max-w-3xl mx-auto">Tus números base son solo la punta del iceberg de tu Árbol de la Vida personal. Adquiere el estudio cabalístico completo para descifrar el mensaje secreto detrás de tu {userPayload.fecha_nacimiento}.</p>
          <a href="https://sabiduriadealma.com/" target="_blank" class="inline-block border border-gray-900 text-gray-900 px-8 py-3 rounded-lg hover:bg-gray-50 transition-colors font-medium">Reservar Lectura Personal</a>
        </div>
      </div>
    )}
  </main>
</Layout>
